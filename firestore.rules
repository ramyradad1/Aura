rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isEmailAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "ramyradad@gmail.com" || 
              request.auth.token.email == "ramyradad10@gmail.com");
    }

    function isAdmin() {
      return isAuthenticated() && (
        isEmailAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             data.role in ['user', 'admin', 'editor'] &&
             data.createdAt is string;
    }
    
    function isValidPerfume(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.category in ['men', 'women', 'unisex'] &&
             data.inspiredBy is string && data.inspiredBy.size() < 100 &&
             data.stock is number && data.stock >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 500)) &&
             (!('images' in data) || (data.images is list && data.images.size() < 10)) &&
             (!('notes' in data) || (data.notes is map)) &&
             (!('sizes' in data) || (data.sizes is list && data.sizes.size() < 10)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('reviewCount' in data) || (data.reviewCount is number && data.reviewCount >= 0)) &&
             (!('brand' in data) || (data.brand is string && data.brand.size() < 100)) &&
             (!('id' in data) || data.id is string) &&
             (!('createdAt' in data) || data.createdAt is string);
    }
    
    function isValidOrder(data, isCreate) {
      return data.userId is string && (isCreate ? data.userId == request.auth.uid : true) &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.totalAmount is number && data.totalAmount > 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.paymentMethod in ['cod', 'card'] &&
             data.shippingAddress is string && data.shippingAddress.size() > 0 && data.shippingAddress.size() < 500 &&
             data.createdAt is string &&
             (!('id' in data) || data.id is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isEmailAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isEmailAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isEmailAdmin());
      allow delete: if isEmailAdmin();
    }

    match /perfumes/{perfumeId} {
      allow read: if true; // Public read
      allow create: if isAdmin() && isValidPerfume(request.resource.data);
      allow update: if isAdmin() && isValidPerfume(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data, true) && request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && isValidOrder(request.resource.data, false) && 
                    ((isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending') || isAdmin());
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.rating is number && 
                    request.resource.data.rating >= 1 && 
                    request.resource.data.rating <= 5 &&
                    request.resource.data.text is string && 
                    request.resource.data.text.size() <= 1000;
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /suppliers/{supplierId} {
      allow read, write: if isAdmin();
    }

    match /purchase_orders/{purchaseOrderId} {
      allow read, write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /crm_interactions/{interactionId} {
      allow read, write: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
