{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsx scripts/generate-sitemap.ts && tsx scripts/generate-product-feed.ts && vite build",
    "build:sitemap": "tsx scripts/generate-sitemap.ts",
    "build:feed": "tsx scripts/generate-product-feed.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "seo:run": "tsx scripts/seo-cron.ts",
    "seo:cron": "tsx scripts/seo-cron.ts --cron",
    "snap": "react-snap"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/shop",
      "/shop/men",
      "/shop/women",
      "/about",
      "/contact"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@heroui/react": "^3.0.1",
    "@heroui/theme": "^2.4.26",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "croner": "^10.0.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.1.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.18",
    "autoprefixer": "^10.4.21",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
